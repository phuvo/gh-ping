{
  "name": "gh-ping",
  "version": "0.1.0",
  "description": "GitHub notification alerts via OS notifications, powered by gh CLI",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "gh-ping": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "github",
    "notifications",
    "cli",
    "desktop-notifications"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "node-notifier": "^10.0.1",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/node-notifier": "^8.0.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
